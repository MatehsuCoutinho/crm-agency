generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(uuid())
  name          String
  email         String    @unique
  password      String
  role          Role      @default(ATTENDANT)
  active        Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  clients       Client[]  @relation("AssignedClients")
  clientProfile Client?   @relation("ClientUser")
  messages      Message[]
  tickets       Ticket[]  @relation("AssignedTickets")
}

model Client {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  phone        String
  assignedToId String?
  assignedTo   User?    @relation("AssignedClients", fields: [assignedToId], references: [id])
  userId       String   @unique
  user         User     @relation("ClientUser", fields: [userId], references: [id])
  tickets      Ticket[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
}

model Ticket {
  id           String         @id @default(uuid())
  title        String
  description  String
  status       TicketStatus   @default(NEW)
  priority     TicketPriority @default(LOW)
  clientId     String
  client       Client         @relation(fields: [clientId], references: [id])
  assignedToId String?
  assignedTo   User?          @relation("AssignedTickets", fields: [assignedToId], references: [id])
  messages     Message[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
}

model Message {
  id        String   @id @default(uuid())
  content   String
  ticketId  String
  ticket    Ticket   @relation(fields: [ticketId], references: [id])
  senderId  String
  sender    User     @relation(fields: [senderId], references: [id])
  createdAt DateTime @default(now())
}

model Settings {
  id           String  @id @default(uuid())
  companyName  String?
  logoUrl      String?
  primaryColor String?
}

enum Role {
  ADMIN
  ATTENDANT
  CLIENT
}

enum ClientStatus {
  NEW
  ACTIVE
  INACTIVE
}

enum TicketStatus {
  NEW
  IN_PROGRESS
  WAITING_CLIENT
  DONE
}
