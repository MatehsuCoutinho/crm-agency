generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       String  @id @default(uuid())
  name     String
  email    String  @unique
  password String
  role     Role    @default(ATTENDANT)
  active   Boolean @default(true)
  createdAt DateTime @default(now())

  clients  Client[]  @relation("UserClients")
  messages Message[]
  tickets  Ticket[]
}

model Client {
  id        String       @id @default(uuid())
  name      String
  company   String?
  email     String?
  phone     String?
  status    ClientStatus @default(NEW)
  createdAt DateTime     @default(now())

  assignedToId String?
  assignedTo   User?   @relation("UserClients", fields: [assignedToId], references: [id])

  tickets Ticket[]
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
}

model Ticket {
  id        String       @id @default(uuid())
  status    TicketStatus @default(NEW)
  createdAt DateTime     @default(now())

  clientId String
  client   Client @relation(fields: [clientId], references: [id])

  messages     Message[]
  priority     TicketPriority @default(LOW)
  assignedToId String?
  assignedTo   User?          @relation(fields: [assignedToId], references: [id])
}

model Message {
  id        String   @id @default(uuid())
  content   String
  createdAt DateTime @default(now())

  ticketId String
  ticket   Ticket @relation(fields: [ticketId], references: [id])

  senderId String
  sender   User   @relation(fields: [senderId], references: [id])
}

model Settings {
  id           String  @id @default(uuid())
  companyName  String?
  logoUrl      String?
  primaryColor String?
}

enum Role {
  ADMIN
  ATTENDANT
}

enum ClientStatus {
  NEW
  ACTIVE
  INACTIVE
}

enum TicketStatus {
  NEW
  IN_PROGRESS
  WAITING_CLIENT
  DONE
}
